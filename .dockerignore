# ──────────────────────────────────────────────
# Docker Ignore — Debiasiq AI
# ──────────────────────────────────────────────

# Version Control
.git
.gitignore

# Environment Variables & Secrets (injected at runtime)
.env
*.env
secret/
.streamlit/secrets.toml
firebase_key.json

# Python Cache & Bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
env.bak/
venv.bak/

# Project Specific
logs/
reports/
scripts/
api_audit.jsonl

# Exclude development tests
test_*.py

# Large data files
data/*.csv
!data/final_merged_cleaned.csv

# Allow pipeline joblib models but block temporary files
pipeline/*.tmp
!pipeline/*.joblib
!pipeline/*.json

# Nested duplicate repo (not needed in the Docker image)
bias-detection-system/

# Build/IDE artifacts
.idea/
.vscode/
*.swp
*.swo
.cache/
