# ======================
# Python
# ======================
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ======================
# Virtual Environment
# ======================
venv/
env/
.venv/
.env/

# ======================
# Data Files (IMPORTANT)
# ======================
data/
*.csv
*.xlsx
*.parquet

# ======================
# Model Files
# ======================
*.pkl
*.joblib
*.h5
!pipeline/*.joblib

# ======================
# Logs
# ======================
*.log
logs/

# ======================
# Streamlit
# ======================
.streamlit/
# Allow the frontend theme/server config (needed for Render deployment)
!frontend/.streamlit/
!frontend/.streamlit/config.toml

# ======================
# Jupyter Notebook
# ======================
.ipynb_checkpoints/

# ======================
# OS Files
# ======================
.DS_Store
Thumbs.db

# ======================
# Secrets / Credentials
# ======================
*.env
*.key
*.json
!pipeline/*.json
# Allow the frontend user store (initial accounts — no secrets inside)
!frontend/users.json

# ======================
# Build / Cache
# ======================
build/
dist/
.cache/